// JuryFlow - Prisma Schema
// PostgreSQL + Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  organizer
  jury
  supervisor
}

enum EventStatus {
  draft
  open
  deliberation
  closed
}

enum ScaleType {
  SCALE_0_5
  SCALE_0_10
  SCALE_0_20
}

enum DeliberationStatus {
  open
  locked
}

enum QuestionType {
  TEXT
  MULTIPLE_CHOICE
  YES_NO
  DATE
  NUMBER
}

enum ResourceType {
  API_CREDENTIAL
  LINK
  TEXT_INFO
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified Boolean   @default(false)
  name          String?
  role          UserRole  @default(organizer)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  juryAssignments JuryAssignment[]
  grades          Grade[]
  sessions        Session[]
  accounts        Account[]
}

model Event {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  status      EventStatus @default(draft)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  teams               Team[]
  criteria            Criterion[]
  juryAssignments     JuryAssignment[]
  deliberations       Deliberation[]
  invitedParticipants InvitedParticipant[]
  checkinLinks        CheckinLink[]
  participantCheckins ParticipantCheckin[]
  customQuestions     CustomQuestion[]
  resources           EventResource[]
}

model Team {
  id         String   @id @default(cuid())
  eventId    String
  name       String
  membersJson String @default("[]") // JSON array of member names
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  event  Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  grades Grade[]
}

model Criterion {
  id        String    @id @default(cuid())
  eventId   String
  name      String
  weight    Float     // coefficient > 0
  scaleType ScaleType // 0-5, 0-10, 0-20
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  grades Grade[]
}

model JuryAssignment {
  id           String    @id @default(cuid())
  eventId      String
  userId       String?
  pinCode      String    // 6 digits
  magicToken   String?   @unique
  displayName  String?   // optional label for anonymous jury
  isPresident  Boolean   @default(false)
  submittedAt  DateTime?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  magicTokenUsedAt DateTime?

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  grades Grade[]
}

model Grade {
  id                 String   @id @default(cuid())
  teamId             String
  criterionId        String
  juryAssignmentId   String
  value              Int      // note within scale
  comment            String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  team            Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  criterion       Criterion       @relation(fields: [criterionId], references: [id], onDelete: Cascade)
  juryAssignment  JuryAssignment  @relation(fields: [juryAssignmentId], references: [id], onDelete: Cascade)

  @@unique([teamId, criterionId, juryAssignmentId])
  users User[]
}

model Deliberation {
  id        String             @id @default(cuid())
  eventId   String
  status    DeliberationStatus @default(open)
  closedAt  DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  event             Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rankingSnapshots  RankingSnapshot[]
}

model RankingSnapshot {
  id             String   @id @default(cuid())
  deliberationId String
  rankingsJson   String   // JSON array of { teamId, rank, score, ... }
  createdAt      DateTime @default(now())

  deliberation Deliberation @relation(fields: [deliberationId], references: [id], onDelete: Cascade)
}

model InvitedParticipant {
  id         String   @id @default(cuid())
  eventId    String
  name       String
  email      String?
  phone      String?
  profession String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  event               Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  participantCheckins ParticipantCheckin[]

  @@index([eventId])
  @@index([eventId, name])
}

model CheckinLink {
  id        String   @id @default(cuid())
  eventId   String   @unique
  token     String   @unique @default(cuid())
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model ParticipantCheckin {
  id                   String   @id @default(cuid())
  eventId              String
  invitedParticipantId String?
  name                 String
  email                String
  phone                String
  profession           String
  photoConsent         Boolean
  isInvited            Boolean   @default(false)
  checkedInAt          DateTime @default(now())
  updatedAt            DateTime @updatedAt

  event              Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  invitedParticipant InvitedParticipant? @relation(fields: [invitedParticipantId], references: [id], onDelete: SetNull)
  answers            ParticipantAnswer[]
  unlockedResources  ParticipantResource[]
  assignedCredentials ApiCredential[]

  @@index([eventId])
  @@index([eventId, name])
  @@index([eventId, email])
}

model CustomQuestion {
  id         String      @id @default(cuid())
  eventId    String
  label      String
  type       QuestionType
  options    String?     // JSON array for MULTIPLE_CHOICE
  isRequired Boolean     @default(false)
  order      Int         @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  event   Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  answers ParticipantAnswer[]

  @@index([eventId])
  @@index([eventId, order])
}

model ParticipantAnswer {
  id                 String   @id @default(cuid())
  participantCheckinId String
  customQuestionId   String
  value              String   // JSON for MULTIPLE_CHOICE, string for others
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  participantCheckin ParticipantCheckin @relation(fields: [participantCheckinId], references: [id], onDelete: Cascade)
  customQuestion     CustomQuestion     @relation(fields: [customQuestionId], references: [id], onDelete: Cascade)

  @@unique([participantCheckinId, customQuestionId])
}

model EventResource {
  id          String       @id @default(cuid())
  eventId     String
  type        ResourceType
  title       String
  description String?
  isActive    Boolean      @default(true)
  url         String?
  fileName    String?
  content     String?      @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  event                Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  apiCredentials       ApiCredential[]
  participantResources ParticipantResource[]

  @@index([eventId])
}

model ApiCredential {
  id              String              @id @default(cuid())
  resourceId      String
  participantHint String?
  value           String
  assignedToId    String?
  assignedAt      DateTime?
  createdAt       DateTime            @default(now())

  resource             EventResource         @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  assignedTo           ParticipantCheckin?   @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  participantResources ParticipantResource[]

  @@index([resourceId])
  @@index([assignedToId])
}

model ParticipantResource {
  id                   String   @id @default(cuid())
  participantCheckinId String
  resourceId           String
  apiCredentialId      String?
  unlockedAt           DateTime @default(now())

  participantCheckin ParticipantCheckin @relation(fields: [participantCheckinId], references: [id], onDelete: Cascade)
  resource           EventResource      @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  apiCredential      ApiCredential?     @relation(fields: [apiCredentialId], references: [id], onDelete: SetNull)

  @@unique([participantCheckinId, resourceId])
  @@index([participantCheckinId])
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id           String    @id @default(cuid())
  accountId    String
  providerId   String
  userId       String
  accessToken  String?
  refreshToken String?
  idToken      String?
  expiresAt    DateTime?
  scope        String?
  password     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}
